# Get compact letter display from Tukey HSD
# Groups sharing a letter are NOT significantly different
get_letters_one_species <- function(df, metric) {

  sub <- df %>%
    filter(!is.na(.data[[metric]]), !is.na(stage)) %>%
    droplevels()

  # Keep only stages with at least 2 samples
  stage_counts <- table(sub$stage)
  keep_stages <- names(stage_counts[stage_counts >= 2])

  sub <- sub %>%
    filter(stage %in% keep_stages) %>%
    droplevels()

  if (nlevels(sub$stage) < 2) {
    return(data.frame(stage = levels(sub$stage), Letters = "a"))
  }

  # aov() = one-way ANOVA
  fit <- aov(stats::as.formula(paste(metric, "~ stage")), data = sub)

  # TukeyHSD() = all pairwise post hoc comparisons
  tuk <- TukeyHSD(fit, "stage")

  # multcompLetters4() converts pairwise comparisons into compact letters
  cld <- multcompView::multcompLetters4(fit, tuk)
  letters_vec <- cld[[1]]$Letters

  data.frame(
    stage = names(letters_vec),
    Letters = as.character(letters_vec),
    row.names = NULL
  )
}

# Save ANOVA and Tukey results for one species + one metric
run_alpha_stats_one_species <- function(df, metric, species_name) {

  sub <- df %>%
    filter(seaweed == species_name, !is.na(.data[[metric]]), !is.na(stage)) %>%
    droplevels()

  stage_counts <- table(sub$stage)
  keep_stages <- names(stage_counts[stage_counts >= 2])

  sub <- sub %>%
    filter(stage %in% keep_stages) %>%
    droplevels()

  if (nlevels(sub$stage) < 2) {
    return(NULL)
  }

  fit <- aov(stats::as.formula(paste(metric, "~ stage")), data = sub)

  anova_tab <- as.data.frame(summary(fit)[[1]])
  anova_tab$term <- rownames(anova_tab)
  rownames(anova_tab) <- NULL

  tukey_tab <- as.data.frame(TukeyHSD(fit, "stage")$stage)
  tukey_tab$contrast <- rownames(tukey_tab)
  rownames(tukey_tab) <- NULL

  list(anova = anova_tab, tukey = tukey_tab)
}

