plot_alpha_one_species <- function(df, metric, species_name, outfile) {

  sub <- df %>%
    filter(seaweed == species_name, !is.na(.data[[metric]]), !is.na(stage)) %>%
    droplevels() %>%
    mutate(stage = droplevels(stage))

  letters_df <- get_letters_one_species(sub, metric)

  # Position letters above the highest point in each stage
  letter_pos <- sub %>%
    group_by(stage) %>%
    summarise(y = max(.data[[metric]], na.rm = TRUE), .groups = "drop") %>%
    left_join(letters_df, by = "stage")

  y_max <- max(letter_pos$y, na.rm = TRUE)
  offset <- 0.08 * y_max

  letter_pos <- letter_pos %>%
    mutate(
      Letters = ifelse(is.na(Letters), "", Letters),
      label_y = y + offset
    )

  species_title <- switch(
    species_name,
    "U.australis" = expression(italic("U. australis")),
    "H.banksii"   = expression(italic("H. banksii")),
    "D.pulchra"   = expression(italic("D. pulchra")),
    species_name
  )

  p <- ggplot(sub, aes(x = stage, y = .data[[metric]], fill = stage)) +
    geom_boxplot(
      width = 0.7,
      outlier.shape = NA,
      colour = "black",
      linewidth = 0.35
    ) +
    geom_jitter(
      width = 0.12,
      height = 0,
      size = 2.2,
      shape = 21,
      fill = "white",
      colour = "black",
      stroke = 0.35
    ) +
    geom_text(
      data = letter_pos,
      aes(x = stage, y = label_y, label = Letters),
      inherit.aes = FALSE,
      vjust = 0,
      size = 5
    ) +
    scale_fill_manual(values = stage_cols, drop = TRUE) +
    labs(title = species_title, x = NULL, y = metric) +
    coord_cartesian(ylim = c(0, max(letter_pos$label_y, na.rm = TRUE) * 1.08)) +
    theme_alpha()

  # ggsave(outfile, p, width = 7, height = 5.5)
