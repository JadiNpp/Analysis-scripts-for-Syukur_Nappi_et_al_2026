    assumption_ok = assumption_ok,
    p_adj = p_adj
  )
}

# --------------------------------------------------
# 4) Helper: extract values from adonis2 output
# --------------------------------------------------
extract_adonis_row <- function(ad) {
  tab <- as.data.frame(ad)

  # Keep only model terms, remove bookkeeping rows
  tab <- tab[!(rownames(tab) %in% c("Residual", "Total")), , drop = FALSE]

  if (nrow(tab) == 0) {
    return(list(
      df = NA_real_,
      F_value = NA_real_,
      R2 = NA_real_,
      p_value = NA_real_
    ))
  }

  cn <- colnames(tab)

  df_col <- cn[grepl("^Df$", cn)]
  f_col  <- cn[grepl("^F$|F.Model|^F value$|^F_value$", cn)]
  r2_col <- cn[grepl("^R2$", cn)]
  p_col  <- cn[grepl("Pr\\(>F\\)|p.value|p_value", cn)]

  list(
    df = if (length(df_col) > 0) as.numeric(tab[[df_col[1]]][1]) else NA_real_,
    F_value = if (length(f_col) > 0) as.numeric(tab[[f_col[1]]][1]) else NA_real_,
    R2 = if (length(r2_col) > 0) as.numeric(tab[[r2_col[1]]][1]) else NA_real_,
    p_value = if (length(p_col) > 0) as.numeric(tab[[p_col[1]]][1]) else NA_real_
  )
}

# --------------------------------------------------
# 5) Helper: extract values from PERMDISP output
# --------------------------------------------------
extract_permdisp_row <- function(pd) {
  tab <- as.data.frame(pd$tab)

  if (nrow(tab) == 0) {
    return(list(
      df = NA_real_,
      F_value = NA_real_,
      p_value = NA_real_
    ))
  }

  cn <- colnames(tab)

  df_col <- cn[grepl("^Df$", cn)]
  f_col  <- cn[grepl("^F$|F.Model|^F value$|^F_value$", cn)]
  p_col  <- cn[grepl("Pr\\(>F\\)|p.value|p_value", cn)]

  list(
    df = if (length(df_col) > 0) as.numeric(tab[[df_col[1]]][1]) else NA_real_,
    F_value = if (length(f_col) > 0) as.numeric(tab[[f_col[1]]][1]) else NA_real_,
    p_value = if (length(p_col) > 0) as.numeric(tab[[p_col[1]]][1]) else NA_real_
  )
}

# --------------------------------------------------
# 6) Helper: compute distance matrices
# --------------------------------------------------
compute_dists <- function(asv_mat) {
  # Remove ASVs absent in all retained samples
  asv_mat <- asv_mat[, colSums(asv_mat) > 0, drop = FALSE]

  if (ncol(asv_mat) == 0) {
    return(NULL)
  }

  # Aitchison distance: CLR transform with pseudocount 1
  log_mat <- log(asv_mat + 1)
  clr <- sweep(log_mat, 1, rowMeans(log_mat), "-")
  dist_ait <- dist(clr)

  # Sorensen distance: binary Bray-Curtis
  dist_sor <- vegdist(asv_mat, method = "bray", binary = TRUE)

  list(
    Aitchison = dist_ait,
    Sorensen = dist_sor
  )
}

# --------------------------------------------------
# 7) Helper: pairwise PERMANOVA for one grouping variable
# --------------------------------------------------
pairwise_adonis1 <- function(d, g, permutations = 999, p_adjust = "BH") {
  g <- droplevels(factor(g))
  lvls <- levels(g)

  if (length(lvls) < 2) return(NULL)

  dmat <- as.matrix(d)
  out_list <- list()
  k <- 1

  for (i in 1:(length(lvls) - 1)) {
    for (j in (i + 1):length(lvls)) {

      li <- lvls[i]
      lj <- lvls[j]

      idx <- which(g %in% c(li, lj))
      sub_g <- droplevels(g[idx])

      # Need at least 2 samples in each group
      if (sum(sub_g == li) < 2 || sum(sub_g == lj) < 2) next

      sub_d <- as.dist(dmat[idx, idx, drop = FALSE])

      ad <- tryCatch(
        adonis2(sub_d ~ sub_g, permutations = permutations),
        error = function(e) NULL
      )

      if (is.null(ad)) next

      ad_row <- extract_adonis_row(ad)

      out_list[[k]] <- tibble(
        contrast = paste(li, "vs", lj),
        df = ad_row$df,
        F_value = ad_row$F_value,
        R2 = ad_row$R2,
        p_value = ad_row$p_value
      )

      k <- k + 1
    }
  }

  out <- bind_rows(out_list)

  if (nrow(out) == 0) return(NULL)

  out %>%
    mutate(p_adj = p.adjust(p_value, method = p_adjust))
}

