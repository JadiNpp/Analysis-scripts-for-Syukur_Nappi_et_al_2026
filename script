get_letters_species_metric <- function(df, species_name, metric_name) {

  sub <- df %>%
    filter(seaweed == species_name, Metric == metric_name, !is.na(Value), !is.na(stage)) %>%
    droplevels()

  stage_counts <- table(sub$stage)
  keep_stages <- names(stage_counts[stage_counts >= 2])

  sub <- sub %>%
    filter(stage %in% keep_stages) %>%
    droplevels()

  if (nlevels(sub$stage) < 2) {
    return(data.frame(
      stage = levels(sub$stage),
      Metric = metric_name,
      Letters = "a"
    ))
  }

  fit <- aov(Value ~ stage, data = sub)
  tuk <- TukeyHSD(fit, "stage")
  cld <- multcompView::multcompLetters4(fit, tuk)
  letters_vec <- cld[[1]]$Letters

  data.frame(
    stage = names(letters_vec),
    Metric = metric_name,
    Letters = as.character(letters_vec),
    row.names = NULL
  )
}

