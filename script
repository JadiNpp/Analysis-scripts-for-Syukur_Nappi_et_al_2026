standardise_image <- function(path, canvas_width = 3000, canvas_height = 2200, bg = "white") {
  img <- magick::image_read(path)

  info  <- magick::image_info(img)
  img_w <- info$width[1]
  img_h <- info$height[1]

  # fit inside fixed canvas without distortion
  scale_factor <- min(canvas_width / img_w, canvas_height / img_h)
  new_w <- max(1, round(img_w * scale_factor))
  new_h <- max(1, round(img_h * scale_factor))

  # resize proportionally
  img_resized <- magick::image_resize(img, paste0(new_w, "x", new_h))

  # place on fixed canvas, centered
  img_final <- magick::image_extent(
    img_resized,
    geometry = paste0(canvas_width, "x", canvas_height),
    gravity  = "center",
    color    = bg
  )

  as.raster(img_final)
}

