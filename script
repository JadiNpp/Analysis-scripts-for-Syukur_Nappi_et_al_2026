library('mvabund')

# import the ASV data, the sample names should be in the 1st column

Delisea <- read.csv("cleaned_raw_data_Delisea.csv", row.names = 1)

# factor for all samples
Delisea.fact <- read.csv("cleaned_factors_Delisea.csv", row.names = 1)

mv.Delisea <- mvabund(Delisea)

# fit the model

fit_mv.Delisea = manyglm(mv.Delisea ~ Parent + Stage, family = "negative.binomial", data = Delisea.fact, composition=TRUE)

# Check the model fitting plotting the residuals
# plot(fit_mv.ad1.control,vars=15)
# plot(fit_mv.ad1.bs52_ad1,vars=15)
# plot(fit_mv.ad1.bs23_ad1,vars=15)
# plot(fit_mv.bs52_ad1.control,vars=15)
# plot(fit_mv.bs23_ad1.control,vars=15)


# run the statistical test

anova.Delisea = anova(fit_mv.Delisea, nBoot=9999, p.uni="unadjusted")


# Get the multivariate table and univariate p - output
# uni - univariate tests
#########################################################output#############

# for the unadjusted p value

r1 <- data.frame(anova.Delisea$table)
write.csv(r1,"global_Delisea_unadjusted.csv")
r2 <- data.frame(anova.Delisea$uni.p)
write.csv(r2,"uni_Delisea_unadjusted.csv")

save.image("Delisea_unadjusted")


#p-values were adjusted using BH:
#Run mvabund with UNADJUSTED (one factor design)
anova.Delisea$table 
length(which(anova.Delisea$uni.p[2,] < 0.05)) 
diff_05_treat_unadj <- which(anova.Delisea$uni.p[2,] < 0.05)
diff_unadj <- anova.Delisea$uni.p[2,]
print(diff_unadj)

# Adjusting p-values using the Benjamini-Hochberg method
anova.Delisea_pvalues_adjusted <- p.adjust(diff_unadj, method = "BH")

# Display adjusted p-values
print(anova.Delisea_pvalues_adjusted)

# Extract only significant adjusted p-values
significant_adjusted_p_values <- anova.Delisea_pvalues_adjusted[anova.Delisea_pvalues_adjusted < 0.05]
names(significant_adjusted_p_values) 
print(significant_adjusted_p_values) 
names_diff_pvalue_adj <- names(significant_adjusted_p_values)


```
