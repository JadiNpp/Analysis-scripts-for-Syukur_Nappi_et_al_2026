# This function rarefies one subset to its minimum sequencing depth
rarefy_one_group <- function(df) {
  # as.matrix() converts the count table to a numeric matrix for vegan functions
  mat <- as.matrix(df[, asv_cols, drop = FALSE])

  # rowSums() gives total reads per sample
  min_depth <- min(rowSums(mat))

  # rrarefy() randomly subsamples each sample to the same depth
  rarefied_mat <- vegan::rrarefy(mat, sample = min_depth)

  rarefied_df <- as.data.frame(rarefied_mat)
  rarefied_df$sample_ID <- df$sample_ID
  rarefied_df$rarefy_depth <- min_depth

  rarefied_df
}

