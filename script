# --------------------------------------------------
# 3) Helper: create one standard result row
# --------------------------------------------------
make_result_row <- function(
  analysis, species, method, test, term,
  contrast = NA_character_,
  df = NA_real_, F_value = NA_real_, R2 = NA_real_, p_value = NA_real_,
  assumption_ok = NA, p_adj = NA_real_
