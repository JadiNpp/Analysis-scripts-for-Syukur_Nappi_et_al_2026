## SPLIT TAXONOMY COLUMN
```{r}
# Libraries
ASV_data_with_taxonomy_split <- ASV_cleaned %>%
  
  # 1) Remove everything inside parentheses, including the parentheses
  mutate(
    Taxonomy_clean = str_remove_all(Taxonomy, "\\([^)]*\\)")
  ) %>%
  
  # 2) Split the cleaned taxonomy column into 7 new columns
  separate(
    Taxonomy_clean,
    into = c("Domain", "Phylum", "Class", "Order",
             "Family", "Genus", "Species"),
    sep = ";",
    remove = FALSE   # keeps the cleaned taxonomy column
  ) %>%
  
  # 3) Remove any extra spaces that might remain
  mutate(
    across(c(Domain, Phylum, Class, Order, Family, Genus, Species),
           str_trim)
  )

ASV_abundance_table <- ASV_data_with_taxonomy_split %>%
  dplyr::select(
    -Domain, -Phylum, -Class, -Order,
    -Family, -Genus, -Species,
    -Taxonomy, -Taxonomy_clean
  )
ASV_taxonomy_table <- ASV_data_with_taxonomy_split %>%
  dplyr::select(ASV_ID,
    Domain, Phylum, Class, Order,
    Family, Genus, Species
  )
