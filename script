# Top 25 within a subset of sample_types
get_top25_subset <- function(df, sample_types, topN = 25) {
  df %>%
    filter(sample_type %in% sample_types) %>%
    group_by(Genus) %>%
    summarise(mean_ab = mean(RelAb), .groups = "drop") %>%
    arrange(desc(mean_ab)) %>%
    slice_head(n = topN) %>%
    pull(Genus)
