make_taxaplot_stagefacet_top25_subset <- function(df, sample_types, outfile, topN = 25) {

  # compute Top 25 for THIS subset only
  top_genera <- get_top25_subset(df, sample_types, topN = topN)

  sub <- df %>%
    filter(sample_type %in% sample_types) %>%
    mutate(Genus = ifelse(Genus %in% top_genera, Genus, "Others")) %>%
    group_by(Sample, sample_type, stage, Genus) %>%
    summarise(RelAb = sum(RelAb), .groups = "drop")

  # legend order
  legend_levels <- c(top_genera, "Others")
  sub$Genus <- factor(sub$Genus, levels = legend_levels)

  # italic legend labels
