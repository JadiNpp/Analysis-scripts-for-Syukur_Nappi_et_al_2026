# -------------------------
# Axis limits helper (fixed within each distance across all subsets)
# -------------------------
get_global_limits <- function(df_list, pad_frac = 0.05) {
  allx <- unlist(lapply(df_list, \(df) df$PCoA1))
  ally <- unlist(lapply(df_list, \(df) df$PCoA2))
  xr <- range(allx, finite = TRUE)
  yr <- range(ally, finite = TRUE)
  xpad <- diff(xr) * pad_frac
  ypad <- diff(yr) * pad_frac
  list(xlim = c(xr[1] - xpad, xr[2] + xpad),
       ylim = c(yr[1] - ypad, yr[2] + ypad))
}

