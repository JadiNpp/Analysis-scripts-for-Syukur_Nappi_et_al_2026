# -------------------------------
# 2) Define rarefaction groups
# -------------------------------

# Join ASV counts to metadata, then assign the rarefaction subset
# case_when() = create a new variable based on multiple conditions
alpha_input <- sample_by_asv %>%
  left_join(meta_alpha, by = "sample_ID") %>%
  mutate(
    rarefy_group = case_when(
      seaweed == "U.australis" | stage %in% c("Seawater_I/II", "Seawater_III/IV") ~ "Uaustralis_seawater",
      seaweed == "H.banksii" ~ "Hbanksii",
      seaweed == "D.pulchra" ~ "Dpulchra",
      TRUE ~ NA_character_
    )
